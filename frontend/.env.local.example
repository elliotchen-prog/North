# OpenRouter API key – used for /api/analyze and /api/message
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Optional: override model (defaults to openrouter/hunter-alpha)
# OPENROUTER_MODEL=openrouter/hunter-alpha

# Use real API instead of mock data (set to "false" to enable)
NEXT_PUBLIC_USE_MOCK_API=false

# Optional: API base URL (defaults to /api for same-origin)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
